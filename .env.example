# BYOK: LLM keys are NOT read from here. Each visitor supplies their own Claude or
# OpenAI key in the app (the "Connect AI" button), used in-memory per request and
# never stored. Nothing below is required to run the app.

# Optional — LangSmith tracing/observability
LANGCHAIN_TRACING_V2=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=mise-en-place

# Optional — override default model IDs per provider
# ANTHROPIC_PLANNER_MODEL=claude-sonnet-4-6
# ANTHROPIC_LIGHT_MODEL=claude-haiku-4-5-20251001
# OPENAI_PLANNER_MODEL=gpt-5.5
# OPENAI_LIGHT_MODEL=gpt-5.4-mini

# Optional — Spoonacular (recipe/nutrition enrichment), only if used
SPOONACULAR_API_KEY=
